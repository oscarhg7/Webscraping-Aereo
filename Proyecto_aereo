def unir_excels(path_1: str, path_2: str, salida: str, origen_1: str = "domestico", origen_2: str = "internacional") -> None:
    """Une dos excels y exporta. Si solo existe uno, lo exporta igualmente con su columna 'origen'."""
    existe_1 = os.path.exists(path_1)
    existe_2 = os.path.exists(path_2)

    if not existe_1 and not existe_2:
        log.error("No se puede generar '%s': ninguno de los dos archivos existe.", os.path.basename(salida))
        log.error("  → %s", path_1)
        log.error("  → %s", path_2)
        return

    dfs = []

    if existe_1:
        df1 = pd.read_excel(path_1, engine="openpyxl")
        df1.columns = [c.strip() for c in df1.columns]
        df1["origen"] = origen_1
        dfs.append(df1)
    else:
        log.warning("Archivo no encontrado (se continúa sin él): %s", path_1)

    if existe_2:
        df2 = pd.read_excel(path_2, engine="openpyxl")
        df2.columns = [c.strip() for c in df2.columns]
        df2["origen"] = origen_2
        dfs.append(df2)
    else:
        log.warning("Archivo no encontrado (se continúa sin él): %s", path_2)

    union = (
        pd.concat(dfs, ignore_index=True)
        .drop_duplicates()
        .pipe(filtrar_clases)
        .pipe(deduplicar_mas_baratos)
    )

    union.to_excel(salida, index=False, engine="openpyxl")
    log.info("Excel exportado: %s (%d filas)", salida, len(union))

    medias = calcular_medias(union)
    log.info("Medias:\n%s", medias.to_string(index=False))



def agregar_hoja_medias(path_excel: str, hoja_nombre: str = "Medias") -> None:
    """Abre un archivo Excel ya existente y añade una pestaña con el precio medio
    por trayecto y clase.

    No se incluye ningún día adicional porque los archivos de unión no contienen
    fechas; la agrupación se limita a vuelo ("Trayecto") y categoría ("Clase").

    Si la hoja ya existe se reemplaza. Se usa el mismo motor de openpyxl que en
    el resto del script.
    """
    if not os.path.exists(path_excel):
        log.error("No se puede abrir '%s': no existe", path_excel)
        return

    df = pd.read_excel(path_excel, engine="openpyxl")
    df.columns = [c.strip() for c in df.columns]

    if "Precio" not in df.columns or "Trayecto" not in df.columns or "Clase" not in df.columns:
        log.error("El fichero %s no tiene las columnas necesarias", path_excel)
        return

    # limpiar y calcular medias individuales por clase
    df["_precio_num"] = limpiar_precio(df["Precio"])
    medias = (
        df.groupby(["Trayecto", "Clase"])["_precio_num"]
          .mean()
          .round(2)
          .reset_index()
          .rename(columns={"_precio_num": "Precio medio (€)"})
    )

    # escribir la nueva hoja en el libro existente
    with pd.ExcelWriter(path_excel, engine="openpyxl", mode="a", if_sheet_exists="replace") as writer:
        medias.to_excel(writer, sheet_name=hoja_nombre, index=False)

    log.info("Hoja '%s' añadida a %s", hoja_nombre, path_excel)

def actualizar_historico(df: pd.DataFrame, ruta_base: str) -> None:
    """Añade los nuevos datos al histórico CSV."""

    ruta_historico = os.path.join(ruta_base, "historico_vuelos.csv")

    df = df.copy()
    df["fecha_scraping"] = date.today()

    if os.path.exists(ruta_historico):
        historico = pd.read_csv(ruta_historico)
        df = pd.concat([historico, df], ignore_index=True)

    df.to_csv(ruta_historico, index=False)

    log.info("Histórico actualizado: %s (%d filas)", ruta_historico, len(df))

